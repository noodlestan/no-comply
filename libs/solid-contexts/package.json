{
  "name": "@no-comply/solid-contexts",
  "version": "0.0.11",
  "description": "Context-aware services and providers for SolidJS applications and component libraries.",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlestan/no-comply.git",
    "directory": "libs/solid-contexts"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "files": [
    "src",
    "LICENSE-MIT"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "lint": "prettier . -c && eslint . && tsc --noEmit",
    "lint:fix": "prettier . -c --write && eslint . --fix",
    "build:clean": "rm -rf dist",
    "build": "vite build",
    "extract": "tsx scripts/extract.ts",
    "ci": "npm run build:clean && tsc --noEmit && npm run build && npm run extract"
  },
  "dependencies": {
    "@no-comply/solid-accessibility": "0.0.11",
    "@no-comply/solid-primitives": "0.0.11",
    "@solid-primitives/map": "0.4.11",
    "@solid-primitives/refs": "1.0.8",
    "@solid-primitives/set": "0.4.11",
    "solid-services": "4.3.2",
    "ts-deepmerge": "7.0.0"
  },
  "peerDependencies": {
    "html-parse-string": "^0.0.9",
    "i18next": "^24.2.3",
    "lucide-solid": "^0.453.0",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@no-comply/meta-entities": "0.0.11",
    "@purrception/source-fs": "0.0.11",
    "tsx": "^4.20.3",
    "vite": "^6.2.2",
    "vite-plugin-solid": "^2.11.6",
    "vite-plugin-solid-svg": "^0.8.1",
    "vite-plugin-top-level-await": "^1.5.0",
    "vitest": "^3.0.9"
  }
}
