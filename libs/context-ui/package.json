{
  "name": "@noodlestan/context-ui",
  "version": "0.0.11",
  "description": "Context-aware application services, and controllers built with SolidJS.",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlestan/context-ui"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "files": [
    "src",
    "LICENSE-MIT"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "lint": "prettier . -c && eslint . && tsc --noEmit",
    "lint:fix": "prettier . -c --write && eslint . --fix",
    "build:clean": "rm -rf dist",
    "build": "vite build",
    "ci": "npm run build:clean && tsc --noEmit && npm run build"
  },
  "dependencies": {
    "@noodlestan/context-ui-aria": "0.0.11",
    "@noodlestan/context-ui-primitives": "0.0.11",
    "@solid-primitives/map": "0.4.11",
    "@solid-primitives/refs": "1.0.8",
    "@solid-primitives/set": "0.4.11",
    "solid-services": "4.3.2",
    "ts-deepmerge": "7.0.0"
  },
  "peerDependencies": {
    "html-parse-string": "^0.0.9",
    "i18next": "^24.2.3",
    "lucide-solid": "^0.453.0",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "vite": "^6.2.2",
    "vite-plugin-solid": "^2.11.6",
    "vite-plugin-solid-svg": "^0.8.1",
    "vite-plugin-top-level-await": "^1.5.0",
    "vitest": "^3.0.9"
  }
}
