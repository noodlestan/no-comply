{
  "name": "AriaPressable",
  "kind": "composable",
  "category": "action",
  "package": "@no-comply/solid-accessibility",
  "module": "./lib/solid-accessibility/src/controllers/pressable",
  "factories": [
    {
      "name": "createAriaPressable",
      "params": [{ "name": "props", "type": "PressableProps" }],
      "returns": "AriaGenericPressableAPI",
      "description": "Creates an ARIA pressable controller with a dynamic role."
    },
    {
      "name": "createAriaPressable",
      "generic": {
        "name": "T",
        "constraint": "PressableRoleName",
        "default": "PressableRoleName"
      },
      "params": [
        { "name": "props", "type": "PressableProps" },
        { "name": "staticRole", "type": "T" }
      ],
      "description": "Creates an ARIA pressable controller with a static ARIA role.",
      "returns": {
        "type": "PressableAPI",
        "generic": "T"
      }
    }
  ],
  "types": {
    "PressableType": {
      "type": "union",
      "values": ["button", "submit", "reset"]
    },
    "AriaPressableProps": {
      "type": "object",
      "keys": {
        "tag": { "type": "PressableTagName", "optional": true },
        "role": { "type": "PressableRoleName", "optional": true },
        "type": { "type": "PressableType", "optional": true },
        "tabIndex": { "type": "number | null", "optional": true },
        "disabled": { "type": "boolean", "optional": true }
      }
    },
    "AriaPressableRoot": {
      "type": "object",
      "keys": {
        "component": { "type": "PressableTagName" },
        "role": { "type": "PressableRoleName", "optional": true },
        "type": { "type": "PressableType | undefined" },
        "tabIndex": { "type": "number | undefined" },
        "disabled": { "type": "boolean | undefined" },
        "aria-disabled": { "type": "AriaAttributes['aria-disabled']" },
        "data-disabled": { "type": "'' | undefined" }
      }
    },
    "AriaPressableAPI": {
      "type": "object",
      "generic": {
        "name": "T",
        "constraint": "PressableRoleName",
        "default": "PressableRoleName"
      },
      "keys": {
        "$root": {
          "type": "intersection",
          "entries": [
            "AriaPressableRoot",
            {
              "type": "object",
              "keys": {
                "role": "T"
              }
            }
          ]
        }
      }
    },
    "AriaGenericPressableAPI": {
      "type": "object",
      "keys": {
        "$root": {
          "type": "intersection",
          "entries": [
            "AriaPressableRoot",
            {
              "type": "object",
              "keys": {
                "role": "PressableRoleName | undefined"
              }
            }
          ]
        }
      }
    }
  },
  "dependencies": [
    {
      "name": "PressableRoleName",
      "type": "type"
    },
    {
      "name": "PressableTagName",
      "type": "type"
    },
    {
      "name": "AriaAttributes",
      "type": "type"
    },
    {
      "name": "computedProps",
      "type": "value",
      "source": "@no-comply/solid-primitives"
    }
  ],
  "composes": [],
  "computed": [
    {
      "prop": "component",
      "logic": "defaults to 'button' if tag is not provided",
      "target": "$root"
    },
    {
      "prop": "role",
      "logic": [
        "staticRole takes precedence",
        "otherwise props.role is used",
        "fallback: button unless component is native button or link"
      ],
      "target": "$root"
    },
    {
      "prop": "type",
      "logic": "only if component is 'button'",
      "target": "$root"
    },
    {
      "prop": "tabIndex",
      "logic": "undefined if disabled, otherwise props.tabIndex or 0",
      "target": "$root"
    },
    {
      "prop": "disabled",
      "logic": "only if component is 'button'",
      "target": "$root"
    },
    {
      "prop": "aria-disabled",
      "logic": "true if props.disabled && not native button",
      "target": "$root"
    },
    {
      "prop": "data-disabled",
      "logic": "'' if props.disabled, otherwise undefined",
      "target": "$root"
    }
  ]
}
