{
  "name": "@noodlestan/ui-system",
  "version": "0.0.11",
  "description": "Component library and UI services built with SolidJS.",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlestan/ui-system"
  },
  "type": "module",
  "main": "./src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "LICENSE-MIT"
  ],
  "scripts": {
    "build:clean": "rm -rf dist",
    "build": "vite build",
    "lint": "prettier . -c && eslint . && tsc --noEmit",
    "lint:fix": "prettier . -c --write && eslint . --fix",
    "dev": "vite build --watch",
    "ci": "npm run build:clean && tsc --noEmit && npm run build"
  },
  "dependencies": {
    "@solid-primitives/map": "0.4.11",
    "@solid-primitives/refs": "1.0.8",
    "@solid-primitives/set": "0.4.11",
    "solid-services": "4.3.2",
    "ts-deepmerge": "7.0.0"
  },
  "peerDependencies": {
    "@solidjs/router": "0.10.6",
    "lucide-solid": "0.453.0",
    "solid-js": "1.9.3"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.1",
    "@solidjs/testing-library": "^0.8.6",
    "@types/svgo": "^3.0.0",
    "@vitest/coverage-v8": "^1.2.2",
    "jsdom": "^24.0.0",
    "typescript": "^5.6.3",
    "vite": "^4.5.1",
    "vite-plugin-solid": "^2.5.0",
    "vite-plugin-solid-svg": "^0.6.1",
    "vite-plugin-top-level-await": "^1.4.4",
    "vitest": "^1.6.0"
  }
}
