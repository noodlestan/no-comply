{
  "name": "ui-system",
  "version": "0.0.1",
  "description": "UI system",
  "author": "Andre Torgal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlestan/ui-system"
  },
  "workspaces": [
    "packages/client/apps/*",
    "packages/client/libs/*"
  ],
  "private": true,
  "scripts": {
    "lint": "prettier . -c && eslint .",
    "lint:silent": "prettier . -c --log-level silent && eslint .",
    "test": "vitest --run --coverage",
    "ci:lib-ui-system": "npm run --prefix packages/client/libs/ui-system ci",
    "ci:ui": "npm run ci:lib-ui-system",
    "ci:libs": "npm run ci:ui",
    "ci:app-ui-system-sandbox": "npm run --prefix packages/client/apps/ui-system-sandbox ci",
    "ci:apps": "npm run ci:app-ui-system-sandbox",
    "ci": "npm run ci:libs && npm run ci:apps"
  },
  "devDependencies": {
    "@types/eslint": "^8.44.8",
    "@types/node": "^20.10.3",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "dotenv": "^16.3.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-solid": "^0.13.1",
    "lefthook": "^1.5.5",
    "prettier": "^3.2.5",
    "typescript": "5.3.3"
  }
}
