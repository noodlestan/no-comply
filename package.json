{
  "name": "ui-system",
  "version": "0.0.11",
  "description": "Component library and UI services built with SolidJS.",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/client/apps/*",
    "packages/client/libs/*",
    "packages/cli/*"
  ],
  "engines": {
    "node": "20.10.0"
  },
  "scripts": {
    "lint": "prettier . -c && eslint .",
    "lint:silent": "prettier . -c --log-level silent && eslint .",
    "ci:lib-desginer-decisions": "npm run --prefix packages/client/libs/designer-decisions ci",
    "ci:lib-desginer-shows": "npm run --prefix packages/client/libs/designer-shows ci",
    "ci:lib-ui-system": "npm run --prefix packages/client/libs/ui-system ci",
    "ci:libs": "npm run ci:lib-desginer-decisions && npm run ci:lib-desginer-shows && npm run ci:lib-ui-system",
    "ci:cli-desginer-generators": "npm run --prefix packages/cli/designer-generators ci",
    "ci:cli": "npm run ci:cli-desginer-generators",
    "ci:build-schemas": "npm run --prefix packages/tools/designer-build build:schemas",
    "ci:lib-desginer-schemas": "npm run --prefix packages/client/libs/designer-schemas ci",
    "ci:schemas": "npm run ci:build-schemas && npm run ci:lib-desginer-schemas",
    "ci:app-designer-sandbox": "npm run --prefix packages/client/apps/designer-sandbox ci",
    "ci:app-ui-system-docs": "npm run --prefix packages/client/apps/ui-system-docs ci",
    "ci:app-ui-system-sandbox": "npm run --prefix packages/client/apps/ui-system-sandbox ci",
    "ci:apps": "npm run ci:app-designer-sandbox && npm run ci:app-ui-system-docs && npm run ci:app-ui-system-sandbox",
    "ci": "npm run ci:libs && npm run ci:cli && npm run ci:schemas && npm run ci:apps"
  },
  "devDependencies": {
    "@noodlestan/eslint-config": "0.0.4",
    "@typescript-eslint/eslint-plugin": "8.11.0",
    "dotenv": "16.3.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.1.5",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-solid": "0.14.3",
    "lefthook": "1.5.5",
    "prettier": "3.3.3",
    "typescript": "5.6.3",
    "vitest": "^1.6.0"
  }
}
