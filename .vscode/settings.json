{
  "spellright.language": [
    "en"
  ],
  "spellright.documentTypes": [
    "plaintext",
    "markdown",
    "javascript",
    "typescript",
    "typescriptreact",
    "html",
    "css",
    "mdx",
    "astro"
  ],
  "spellright.parserByClass": {
    "astro": {
      "parser": "code"
    },
    "mdx": {
      "parser": "markdown"
    }
  },
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit"
  },
  "files.exclude": {
    "**/dist": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/dist": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/node_modules": true
  },
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": [
    "src/",
    "dist/",
    "...*/private/.+",
    "./[^./]+/[^./]+"
  ],
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "eslint.options": {
    "extensions": [
      ".js",
      ".jsx",
      ".mdx",
      ".ts",
      ".tsx"
    ],
  },
  "eslint.validate": [
    "mdx",
    "javascript",
    "javascriptreact",
    "html",
    "typescript",
    "typescriptreact",
  ],
  "svg.preview.background": "transparent",
  "editor.inlineSuggest.experimental.emptyResponseInformation": false,
}
