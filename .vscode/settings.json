{
  "spellright.language": ["en"],
  "spellright.documentTypes": [
    "plaintext",
    "markdown",
    "javascript",
    "typescript",
    "typescriptreact",
    "html",
    "css",
    "mdx",
    "astro"
  ],
  "spellright.parserByClass": {
    "astro": {
      "parser": "code"
    },
    "mdx": {
      "parser": "markdown"
    }
  },
  "editor.tabSize": 4,
  "editor.insertSpaces": false,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "never"
  },
  "files.exclude": {
    "**/dist": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/dist": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/node_modules": true
  },
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": [
    "src/",
    "dist/",
    "...*/private/.+",
    "./[^./]+/[^./]+"
  ],
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "eslint.options": {
    "extensions": [".js", ".jsx", ".mdx", ".ts", ".tsx"]
  },
  "eslint.validate": [
    "mdx",
    "javascript",
    "javascriptreact",
    "html",
    "typescript",
    "typescriptreact"
  ],
  "svg.preview.background": "transparent",
  "editor.inlineSuggest.experimental.emptyResponseInformation": false,
  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#1063a2",
    "titleBar.activeForeground": "#ffffff",
    "titleBar.inactiveBackground": "#0c498a",
    "titleBar.inactiveForeground": "#cccccc",
    "sideBar.background": "#000001",
    "sideBar.foreground": "#ced2df"
  }
}
