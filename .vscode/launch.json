  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run vite",
      "runtimeExecutable": "vite",
      "cwd": "${workspaceFolder}",
      "args": []
    },
    {
      "type": "node-terminal",
      "name": "Run Script: extract (libs/solid-composables)",
      "request": "launch",
      "command": "npm run extract",
      "cwd": "${workspaceFolder}/libs/solid-composables"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run Script: mybin (cli/mybin)",
      "runtimeExecutable": "tsx",
      "cwd": "${workspaceFolder}",
      "args": ["cli/mybin/src/index.ts"]
    }
  ]
}
