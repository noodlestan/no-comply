{
  "name": "@noodlestan/designer-decisions",
  "version": "0.0.1",
  "description": "Modeling design decisions.",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlestan/ui-system"
  },
  "main": "dist/index.js",
  "module": "src/index.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "LICENSE-MIT"
  ],
  "scripts": {
    "build:clean": "rm -rf dist",
    "build:cjs": "tsc --project tsconfig.build.json",
    "build:watch": "tsc -w --project tsconfig.build.json",
    "build": "npm run build:clean && npm run build:cjs",
    "lint": "prettier . -c && eslint . && tsc --noEmit",
    "lint:fix": "prettier . -c --write && eslint . --fix",
    "test": "vitest --run --coverage",
    "ci": "npm run build && npm run test"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.1",
    "@vitest/coverage-v8": "^1.2.2",
    "json-schema-to-zod": "^2.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^4.5.1",
    "vitest": "^1.6.0"
  }
}
