{
  "name": "@noodlestan/designer-schemas",
  "version": "0.0.1",
  "description": "A collection of JSON schemas to validate design decision inputs.",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlestan/ui-system"
  },
  "files": [
    "dist",
    "src",
    "LICENSE-MIT"
  ],
  "type": "module",
  "module": "dist/esm/index.js",
  "main": "dist/cjs/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./schemas": "./schemas"
  },
  "scripts": {
    "build:clean": "rm -rf dist",
    "build:lib": "vite build",
    "build:types": "tsc --project tsconfig.esm.json --emitDeclarationOnly && tsc --project tsconfig.cjs.json --emitDeclarationOnly",
    "build": "npm run build:lib && npm run build:types",
    "lint": "prettier . -c && eslint . && tsc --noEmit",
    "lint:fix": "prettier . -c --write && eslint . --fix",
    "dev": "vite build --watch",
    "test": "echo nothing to test",
    "ci": "npm run build:clean && npm run build && npm run test"
  },
  "dependencies": {
    "@noodlestan/designer-generators": "0.0.1",
    "@noodlestan/designer-decisions": "0.0.1"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.1",
    "@solidjs/testing-library": "^0.8.6",
    "@vitest/coverage-v8": "^1.2.2",
    "jsdom": "^24.0.0",
    "json-schema-to-zod": "^2.5.0",
    "typescript": "^5.6.3",
    "vite": "^4.5.1",
    "vite-plugin-solid": "^2.5.0",
    "vitest": "^1.6.0"
  }
}
