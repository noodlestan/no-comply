---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

import { LinkCard } from '@astrojs/starlight/components';


import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const decisions = await getCollection('decisions');

  return decisions.map(decision => ({
    params: { id: decision.id },
    props: { decision },
  }));
}

const { decision } = Astro.props;
const { Content } = await render(decision);

---

<StarlightPage frontmatter={decision.data}>

<LinkCard href="/decisions" title="Other decision types" />


<Content />

</StarlightPage>
