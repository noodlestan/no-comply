---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { LinkCard, Badge, Icon } from '@astrojs/starlight/components';
import { getCollection } from 'astro:content';
import { sidebar } from '../../../sidebar';

const decisionTypes = await getCollection('decisionTypes');
const decisions = await getCollection('decisions');

export async function getStaticPaths() {
    const decisionTypes = await getCollection('decisionTypes');
    const decisionTypesById = decisionTypes.reduce(
        (acc, item) => {
            acc[item.id] = item;
            return acc;
        },
        {} as Record<string, (typeof decisionTypes)[0]>,
    );
    const models = await getCollection('models');
    return models.map(item => ({
        params: { id: item.data.decisionTypeId, model: item.data.model },
        props: { decisionType: decisionTypesById[item.data.decisionTypeId], model: item.data },
    }));
}


const { decisionType, model } = Astro.props;

console.log(decisions, decisionType.id + '/' + model.model)

const samples = decisions.filter(d => d.data.type === decisionType.id + '/' + model.model);

const frontmatter = {
    ...decisionType.data,
    title: decisionType.data.name + ' / ' + model.name,
};
---

<StarlightPage frontmatter={frontmatter} sidebar={sidebar}>
    <p>
        <Badge variant="tip" text={decisionType.data.domain} />
        <Badge variant="note" text={decisionType.data.category} />
    </p>

    <blockquote>
        <p>type: <a href={`/decision-types/${decisionType.id}`}>{decisionType.data.name}</a></p>
        {decisionType.data.description}
    </blockquote>
    <p>model: <code>{model.model}</code></p>
    <blockquote>
        {model.description}
    </blockquote>

    {(samples.length) ?
        <>
            <h3>Samples</h3>
            {
                samples.map(decision => (
                    <li>
                        {decision.data.type}
                        {decision.data.name}
                        {decision.data.params}
                        {decision.data.description}
                    </li>
                ))
            }
        </>
        : <></>
    }

    <h3>{decisionType.data.name} Models</h3>
    {
        decisionType.data.models.map(m => (
            <li>
                {(m.model === model.model) ? <>👉</> : ''}
                <a href={`/decision-types/${decisionType.id}/${m.model}`}>{m.name}</a>
                {m.description}
            </li>
        ))
    }
    <LinkCard href="/decision-types" title="Other decision types" />
</StarlightPage>
