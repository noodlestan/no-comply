---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { LinkCard, Badge } from '@astrojs/starlight/components';
import { getCollection, render } from 'astro:content';

const decisionTypes = await getCollection('decisionTypes');

export async function getStaticPaths() {
    const decisionTypes = await getCollection('decisionTypes');
    return decisionTypes.map(decisionType => ({
        params: { id: decisionType.id },
        props: { decisionType },
    }));
}

const sidebar = [
    {
        label: 'yes!',
        items: decisionTypes.map(d => ({ link: `decision-types/${d.id}`, label: d.data.name })),
    },
];

const { decisionType } = Astro.props;
const { Content } = await render(decisionType);
---

<StarlightPage frontmatter={decisionType.data} sidebar={sidebar}>
    <Badge variant="tip" text={decisionType.data.domain} />
    <Badge variant="note" text={decisionType.data.category} />

    <blockquote>
        {decisionType.data.description}
    </blockquote>

    <Content />

    <LinkCard href="/decision-types" title="Other decision types" />
</StarlightPage>
