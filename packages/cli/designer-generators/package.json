{
  "name": "@noodlestan/designer-generators",
  "version": "0.0.1",
  "description": "Generate schemas for design decision, validators, and transformations.",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:zod": "",
    "build:schemas": "ts-node commands/schemas/generate.ts",
    "build": "npm run build:schemas && vite build",
    "lint": "prettier . -c && eslint . && tsc --noEmit",
    "test": "mocha -r ts-node/register 'src/**/*.test.ts'",
    "test:watch": "mocha -w -r ts-node/register ---watch-files 'src/**/*.ts' 'src/**/*.test.ts'",
    "ci": "tsc --noEmit && npm run test && npm run build:schemas"
  },
  "dependencies": {
    "expect": "^29.7.0",
    "mocha": "^11.0.1",
    "rimraf": "^6.0.1",
    "ts-deepmerge": "7.0.0",
    "typescript-json-schema": "^0.65.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "jsdom": "^24.0.0",
    "json-schema-to-zod": "^2.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
