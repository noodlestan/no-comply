{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "test": {},
    "build:clean": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "extract": {},
    "ci": {
      "dependsOn": ["^ci"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "dev": {
      "dependsOn": ["^lint"],
      "cache": false,
      "persistent": true
    }
  }
}
