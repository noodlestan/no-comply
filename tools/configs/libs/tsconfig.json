{
  "compilerOptions": {
    "skipLibCheck": true, // problems in vitest, @vitest/utils, svgo
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": true,
    "jsxImportSource": "solid-js",
    "jsx": "preserve"
  }
}
