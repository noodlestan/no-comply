{
  "name": "@purrception/lang-ts",
  "version": "0.0.11",
  "description": "Purrception language: lightweight Typescript AST definitions and helpers.",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlestan/no-comply.git",
    "directory": "cli/purrception-lang-ts"
  },
  "type": "module",
  "module": "dist/esm/index.mjs",
  "main": "dist/cjs/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE-MIT"
  ],
  "scripts": {
    "dev": "no-comply-watch",
    "build:clean": "rm -rf dist",
    "build:types:esm": "tsc --project tsconfig.esm.json",
    "build:types:cjs": "tsc --project tsconfig.cjs.json",
    "build": "no-comply-build",
    "test": "echo none yet",
    "test:watch": "vitest",
    "lint": "prettier . -c && eslint . && tsc --noEmit",
    "lint:fix": "prettier . -c --write && eslint . --fix",
    "ci": "npm run build:clean && npm run build && npm run test"
  },
  "dependencies": {
    "@purrception/primitives": "0.0.11"
  },
  "devDependencies": {
    "@no-comply/build-tools": "0.0.11",
    "@types/node": "^24.0.3"
  }
}
